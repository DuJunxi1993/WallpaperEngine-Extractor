<Page x:Class="WallpaperEngine_Extractor.Views.ExtractPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:WallpaperEngine_Extractor.ViewModels"
      xmlns:converters="clr-namespace:WallpaperEngine_Extractor.Converters"
      Background="Transparent"
      Title="提取">

    <Page.DataContext>
        <vm:ExtractViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <!-- 通用卡片样式 -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.M}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <Page.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding BrowseFilesCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExtractCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelExtractCommand}"/>
    </Page.InputBindings>

    <Grid Margin="{DynamicResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============= Row 0: 标题栏 ============= -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="提取 PKG 文件"
                           FontSize="{DynamicResource FontSize.Title}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Style="{StaticResource CaptionTextStyle}"
                           Text="从 Wallpaper Engine PKG 包中提取壁纸资源，支持 TEX 转 PNG"
                           Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Content="取消"
                           Command="{Binding CancelExtractCommand}"
                           Appearance="Secondary"
                           Height="{DynamicResource ControlHeight.M}"
                           MinWidth="80"
                           Margin="0,0,8,0"
                           ToolTip="Esc"
                           Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Dismiss24"/>
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="开始提取"
                           Command="{Binding ExtractCommand}"
                           Appearance="Primary"
                           Height="{DynamicResource ControlHeight.M}"
                           MinWidth="120"
                           ToolTip="Ctrl+E">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Play24"/>
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- ============= Row 1: 输入 + 选项 + 进度 (合并一栏卡片) ============= -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="{DynamicResource CardPadding}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 拖放 / 文件选择 -->
                <Border Grid.Column="0"
                        x:Name="FileSelectionBorder"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.M}"
                        MinHeight="92"
                        AllowDrop="True"
                        DragEnter="FileSelectionBorder_DragEnter"
                        DragLeave="FileSelectionBorder_DragLeave"
                        DragOver="FileSelectionBorder_DragOver"
                        Drop="FileSelectionBorder_Drop">
                    <Grid>
                        <!-- 空状态：显示拖放引导 -->
                        <Grid Visibility="{Binding HasSelectedFiles, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowUpload24"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="拖放 PKG 文件或文件夹到此处"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,8"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ui:Button Content="选择文件" Click="BrowseFiles_Click"
                                               Appearance="Secondary"
                                               MinWidth="96" Height="{DynamicResource ControlHeight.S}"
                                               Margin="0,0,6,0" ToolTip="Ctrl+O"/>
                                    <ui:Button Content="选择文件夹" Click="BrowseFolder_Click"
                                               Appearance="Secondary"
                                               MinWidth="96" Height="{DynamicResource ControlHeight.S}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <!-- 已选择文件列表 -->
                        <Grid Visibility="{Binding HasSelectedFiles, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="10,8,10,4" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="已选择的文件"
                                           FontWeight="SemiBold"
                                           FontSize="{DynamicResource FontSize.Body}"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ui:Button Content="添加" Click="BrowseFiles_Click"
                                               Appearance="Secondary" Height="24"
                                               FontSize="{DynamicResource FontSize.Caption}"
                                               Padding="8,0" Margin="0,0,4,0"/>
                                    <ui:Button Content="清除"
                                               Command="{Binding ClearFilesCommand}"
                                               Appearance="Secondary" Height="24"
                                               FontSize="{DynamicResource FontSize.Caption}"
                                               Padding="8,0"/>
                                </StackPanel>
                            </DockPanel>
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="10,0,10,8">
                                <ItemsControl ItemsSource="{Binding SelectedFiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:SymbolIcon x:Name="FileIcon" Grid.Column="0"
                                                               FontSize="14"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Symbol" Value="Document24"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                    <Setter Property="Symbol" Value="Folder24"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayText}"
                                                           FontSize="{DynamicResource FontSize.Body}"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Grid.Row="2" Margin="10,0,10,6"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding SelectedFiles.Count, StringFormat='共 {0} 项'}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 输出目录 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <TextBlock Text="输出目录" Style="{StaticResource SectionTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding OutputDirectory, Mode=TwoWay}"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Height="{DynamicResource ControlHeight.M}"
                                 Margin="0,0,8,0"/>
                        <ui:Button Grid.Column="1"
                                   Command="{Binding BrowseOutputCommand}"
                                   Appearance="Secondary"
                                   Height="{DynamicResource ControlHeight.M}"
                                   Width="{DynamicResource ControlHeight.M}"
                                   Padding="0"
                                   ToolTip="浏览...">
                            <ui:SymbolIcon Symbol="Folder24"/>
                        </ui:Button>
                    </Grid>
                    <ui:Button Content="打开文件夹"
                               Command="{Binding OpenOutputFolderCommand}"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Height="{DynamicResource ControlHeight.S}"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Padding="12,0"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 选项 + 状态 -->
                <StackPanel Grid.Column="4" VerticalAlignment="Top">
                    <TextBlock Text="选项" Style="{StaticResource SectionTitleStyle}"/>
                    <CheckBox Content="递归搜索子文件夹"
                              IsChecked="{Binding Settings.RecursiveSearch}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="将 TEX 纹理转换为 PNG"
                              IsChecked="{Binding Settings.ConvertTexToPng}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="提取完成后打开输出文件夹"
                              IsChecked="{Binding Settings.OpenOutputAfterExtract}"
                              Margin="0,0,0,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============= Row 2: 输出 (大文件整理 + 预览) ============= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：大图片整理 + 预览 -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="{DynamicResource CardPadding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <TextBlock Text="输出图片"
                                       FontWeight="SemiBold"
                                       FontSize="{DynamicResource FontSize.BodyStrong}"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OrganizerStatusText}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <!-- 空状态 -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding HasLargeFiles, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="Image24"
                                           FontSize="48"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center"/>
                            <TextBlock Text="暂无大于 1MB 的图片"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="提取完成后会自动扫描大图片"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Opacity="0.7"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <!-- 文件列表 -->
                        <ListBox x:Name="LargeFilesList"
                                 ItemsSource="{Binding LargeFiles}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="LargeFilesList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource Radius.S}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="{DynamicResource FontSize.Body}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding RelativePath}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SizeText}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Margin="8,0,12,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Command="{Binding SortByNameCommand}" Appearance="Secondary"
                                   Height="{DynamicResource ControlHeight.S}"
                                   FontSize="{DynamicResource FontSize.Caption}"
                                   Padding="10,0" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="TextSortAscending24" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="按名称"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding SortBySizeCommand}" Appearance="Secondary"
                                   Height="{DynamicResource ControlHeight.S}"
                                   FontSize="{DynamicResource FontSize.Caption}"
                                   Padding="10,0" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowSort24" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="按大小"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding SelectAllLargeFilesCommand}" Appearance="Secondary"
                                   Height="{DynamicResource ControlHeight.S}"
                                   FontSize="{DynamicResource FontSize.Caption}"
                                   Padding="10,0" Margin="0,0,4,0"
                                   Content="全选"/>
                        <ui:Button Command="{Binding DeselectAllLargeFilesCommand}" Appearance="Secondary"
                                   Height="{DynamicResource ControlHeight.S}"
                                   FontSize="{DynamicResource FontSize.Caption}"
                                   Padding="10,0" Margin="0,0,4,0"
                                   Content="取消"/>
                        <ui:Button Command="{Binding SaveSelectedFilesCommand}" Appearance="Primary"
                                   Height="{DynamicResource ControlHeight.S}"
                                   FontSize="{DynamicResource FontSize.Caption}"
                                   Padding="12,0"
                                   Content="保存选中"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右：预览（16:9） -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="{DynamicResource CardPadding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="预览" Style="{StaticResource SectionTitleStyle}"/>
                    <Border x:Name="PreviewContainer"
                            Grid.Row="1"
                            SizeChanged="PreviewContainer_SizeChanged"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        <Border x:Name="PreviewBorder"
                                MinHeight="160"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="{DynamicResource Radius.S}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Viewbox Stretch="Uniform" Margin="8">
                                <Image Source="{Binding PreviewImage}" Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ============= Row 3: 进度条 ============= -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatusText}"
                           FontSize="{DynamicResource FontSize.Caption}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Progress, StringFormat='{}{0}%'}"
                           FontSize="{DynamicResource FontSize.Caption}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <ProgressBar Grid.Row="1"
                         Value="{Binding Progress}"
                         Height="6"
                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                         Background="{DynamicResource ControlFillColorTransparentBrush}"/>
        </Grid>
    </Grid>
</Page>