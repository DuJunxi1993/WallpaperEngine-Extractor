<Page x:Class="WallpaperEngine_Extractor.Views.ExtractPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:WallpaperEngine_Extractor.ViewModels"
      xmlns:converters="clr-namespace:WallpaperEngine_Extractor.Converters"
      Background="Transparent"
      Title="提取">

    <Page.DataContext>
        <vm:ExtractViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="180"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title with Extract Button -->
        <Grid Grid.Row="0" Margin="0,0,0,8" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="提取 PKG 文件"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <ui:Button Grid.Column="1"
                       Content="开始提取"
                       Command="{Binding ExtractCommand}"
                       Appearance="Primary"
                       Height="32"
                       FontSize="13"
                       Padding="20,0"/>
        </Grid>

        <!-- Row 1: Left (File Selection) | Right (Output Dir + Log) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: File Selection Area -->
            <Border Grid.Column="0"
                    x:Name="FileSelectionBorder"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    AllowDrop="True"
                    DragEnter="FileSelectionBorder_DragEnter"
                    DragLeave="FileSelectionBorder_DragLeave"
                    DragOver="FileSelectionBorder_DragOver"
                    Drop="FileSelectionBorder_Drop">
                <Grid>
                    <!-- Drag Drop View (initial state, hidden when HasSelectedFiles=True) -->
                    <Grid x:Name="DragDropView"
                          Visibility="{Binding HasSelectedFiles, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="36"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="拖放 PKG 文件或文件夹到此处"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Margin="0,10,0,0">
                                <ui:Button Content="选择文件"
                                           Click="BrowseFiles_Click"
                                           Appearance="Secondary"
                                           Padding="14,6"
                                           Margin="0,0,8,0"/>
                                <ui:Button Content="选择文件夹"
                                           Click="BrowseFolder_Click"
                                           Appearance="Secondary"
                                           Padding="14,6"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- File List View (shown when HasSelectedFiles=True) -->
                    <Grid Visibility="{Binding HasSelectedFiles, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with buttons -->
                        <Grid Grid.Row="0" Margin="12,10,12,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="已选择的文件"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Content="添加文件"
                                           Click="BrowseFiles_Click"
                                           Appearance="Secondary"
                                           Padding="10,4"
                                           FontSize="11"
                                           Margin="0,0,6,0"/>
                                <ui:Button Content="添加文件夹"
                                           Click="BrowseFolder_Click"
                                           Appearance="Secondary"
                                           Padding="10,4"
                                           FontSize="11"
                                           Margin="0,0,6,0"/>
                                <ui:Button Content="清除"
                                           Command="{Binding ClearFilesCommand}"
                                           Appearance="Secondary"
                                           Padding="10,4"
                                           FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <!-- File List with scrollbar -->
                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="12,0,12,12">
                            <ItemsControl ItemsSource="{Binding SelectedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontSize="12"
                                                   Margin="0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right: Output Directory + Log -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <!-- Output Directory -->
                <Border Grid.Row="0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="输出目录"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,0,0,6"/>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding OutputDirectory, Mode=TwoWay}"
                                     IsReadOnly="True"
                                     Margin="0,0,8,0"
                                     Padding="6,4"
                                     FontSize="11"/>
                            <ui:Button Grid.Column="1"
                                       Content="..."
                                       Command="{Binding BrowseOutputCommand}"
                                       Appearance="Secondary"
                                       Padding="10,4"/>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox Content="递归搜索子文件夹"
                                          IsChecked="{Binding Settings.RecursiveSearch}"
                                          Margin="0,0,0,4"
                                          FontSize="11"/>
                                <CheckBox Content="转换 TEX 为 PNG"
                                          IsChecked="{Binding Settings.ConvertTexToPng}"
                                          FontSize="11"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Content="打开文件夹"
                                       Click="OpenOutputFolder_Click"
                                       Appearance="Secondary"
                                       Padding="12,6"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Log -->
                <Border Grid.Row="2"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="提取日志"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,0,0,6"/>

                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding LogText}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       FontSize="10"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Row 2: Progress Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Opacity="0.7"/>
            </StackPanel>
            <ProgressBar Grid.Row="1"
                         Value="{Binding Progress}"
                         Height="4"/>
        </Grid>

        <!-- Row 3: Output Image -->
        <Border Grid.Row="3"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="输出图片"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding OrganizerStatusText}"
                                   Margin="10,0,0,0"
                                   FontSize="11"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ListView Grid.Row="1"
                              x:Name="LargeFilesList"
                              ItemsSource="{Binding LargeFiles}"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionChanged="LargeFilesList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FileName}"
                                               FontSize="11"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SizeText}"
                                               FontSize="10"
                                               Opacity="0.7"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="按名称"
                                   Command="{Binding SortByNameCommand}"
                                   Appearance="Secondary"
                                   Padding="10,4"
                                   FontSize="11"
                                   Margin="0,0,6,0"/>
                        <ui:Button Content="按大小"
                                   Command="{Binding SortBySizeCommand}"
                                   Appearance="Secondary"
                                   Padding="10,4"
                                   FontSize="11"
                                   Margin="0,0,6,0"/>
                        <ui:Button Content="全选"
                                   Command="{Binding SelectAllLargeFilesCommand}"
                                   Appearance="Secondary"
                                   Padding="10,4"
                                   FontSize="11"
                                   Margin="0,0,6,0"/>
                        <ui:Button Content="取消"
                                   Command="{Binding DeselectAllLargeFilesCommand}"
                                   Appearance="Secondary"
                                   Padding="10,4"
                                   FontSize="11"
                                   Margin="0,0,6,0"/>
                        <ui:Button Content="保存"
                                   Command="{Binding SaveSelectedFilesCommand}"
                                   Appearance="Primary"
                                   Padding="10,4"
                                   FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Preview Panel (fixed 16:9 aspect ratio) -->
                <Border Grid.Column="1"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="4"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Viewbox Stretch="Uniform">
                        <Image Source="{Binding PreviewImage}"
                               Stretch="Uniform"
                               Margin="4"/>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
